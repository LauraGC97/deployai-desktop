<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.deployai.controller.RegisterController"
           styleClass="bg-base">

    <VBox alignment="CENTER" spacing="0" maxWidth="420">

        <!-- Logo y título -->
        <VBox alignment="CENTER" spacing="8">
            <Label text="⬡" style="-fx-font-size: 48px; -fx-text-fill: #7c3aed;"/>
            <Label text="Deploy AI" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Tu asistente de programación" style="-fx-font-size: 13px; -fx-text-fill: #8b949e;"/>
        </VBox>

        <Region minHeight="32"/>

        <!-- Tarjeta de registro -->
        <VBox spacing="16" style="-fx-background-color: #161b22; -fx-background-radius: 12; -fx-padding: 32;">

            <Label text="Crear cuenta" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <!-- Username -->
            <VBox spacing="6">
                <Label text="Nombre de usuario" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <TextField fx:id="usernameField"
                           promptText="tunombre"
                           styleClass="text-input"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Email" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField"
                           promptText="tu@email.com"
                           styleClass="text-input"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Contraseña" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               styleClass="text-input"/>
            </VBox>

            <!-- Error -->
            <Label fx:id="errorLabel"
                   text=""
                   style="-fx-text-fill: #f85149; -fx-font-size: 12px;"
                   wrapText="true"/>

            <!-- Botón registro -->
            <Button fx:id="registerButton"
                    text="Crear cuenta"
                    maxWidth="Infinity"
                    styleClass="button-accent"
                    onAction="#handleRegister"/>

            <!-- Link login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="¿Ya tienes cuenta?" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <Hyperlink text="Inicia sesión" onAction="#goToLogin"
                           style="-fx-text-fill: #7c3aed; -fx-font-size: 12px;"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>