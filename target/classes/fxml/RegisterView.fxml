<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.deployai.controller.RegisterController"
           style="-fx-background-color: #080A10;">

    <VBox alignment="CENTER" spacing="0" maxWidth="440"
          style="-fx-padding: 24;">

        <!-- Logo + título -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 24 0;">
            <Label text="⬡"
                   style="-fx-font-size: 52px; -fx-text-fill: #22D3EE;"/>
            <Label text="Deploy AI"
                   style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #F0F9FF;"/>
            <Label text="Tu asistente de programación"
                   style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
        </VBox>

        <!-- Tarjeta -->
        <VBox spacing="18"
              style="-fx-background-color: #161922; -fx-background-radius: 16; -fx-padding: 36; -fx-border-color: rgba(34,211,238,0.12); -fx-border-radius: 16; -fx-border-width: 1;">

            <!-- Título -->
            <VBox spacing="4">
                <Label style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #F0F9FF;">
                    <text><![CDATA[const register = () => {]]></text>
                </Label>
                <Label text="Crea tu cuenta para empezar"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
            </VBox>

            <!-- Username -->
            <VBox spacing="6">
                <Label text="USUARIO"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11px; -fx-text-fill: #8B9BB4; -fx-letter-spacing: 1px;"/>
                <TextField fx:id="usernameField"
                           promptText="tunombre"
                           style="-fx-background-color: #0D0F18; -fx-text-fill: #F0F0F0; -fx-prompt-text-fill: #4B5563; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-border-width: 1; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="6">
                <Label text="EMAIL"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11px; -fx-text-fill: #8B9BB4; -fx-letter-spacing: 1px;"/>
                <TextField fx:id="emailField"
                           promptText="tu@email.com"
                           style="-fx-background-color: #0D0F