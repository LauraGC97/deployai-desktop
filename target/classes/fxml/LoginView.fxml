<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.deployai.controller.LoginController"
           style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="0" maxWidth="420">

        <!-- Logo y título -->
        <VBox alignment="CENTER" spacing="8">
            <Label text="⬡" style="-fx-font-size: 48px; -fx-text-fill: #7c3aed;"/>
            <Label text="Deploy AI" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Tu asistente de programación" style="-fx-font-size: 13px; -fx-text-fill: #8b949e;"/>
        </VBox>

        <Region minHeight="32"/>

        <!-- Tarjeta -->
        <VBox spacing="16" style="-fx-background-color: #161b22; -fx-background-radius: 12; -fx-padding: 32;">

            <Label text="Iniciar sesión" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <VBox spacing="6">
                <Label text="Email" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField"
                           promptText="tu@email.com"
                           style="-fx-background-color: #0d1117; -fx-text-fill: white; -fx-prompt-text-fill: #8b949e; -fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #30363d; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Contraseña" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               style="-fx-background-color: #0d1117; -fx-text-fill: white; -fx-prompt-text-fill: #8b949e; -fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #30363d; -fx-border-radius: 6;"/>
            </VBox>

            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #f85149; -fx-font-size: 12px;" wrapText="true"/>

            <Button fx:id="loginButton"
                    text="Entrar"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="¿No tienes cuenta?" style="-fx-text-fill: #8b949e; -fx-font-size: 12px;"/>
                <Hyperlink text="Regístrate" onAction="#goToRegister"
                           style="-fx-text-fill: #7c3aed; -fx-font-size: 12px; -fx-border-color: transparent;"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>