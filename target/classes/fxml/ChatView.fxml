<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.deployai.controller.ChatController"
            style="-fx-background-color: #0B0D15;">

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: #10121C; -fx-min-width: 260; -fx-max-width: 260; -fx-padding: 20 16 20 16; -fx-border-color: rgba(34,211,238,0.08); -fx-border-width: 0 1 0 0;"
              spacing="0">

            <!-- Header logo -->
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-padding: 0 0 16 0; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                <Label text="⬡" style="-fx-font-size: 22px; -fx-text-fill: #22D3EE;"/>
                <Label text="Deploy AI"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #F0F9FF;"/>
            </HBox>

            <Region minHeight="16"/>

            <!-- Nueva conversación -->
            <Button text="+ Nueva conversación"
                    maxWidth="Infinity"
                    onAction="#newConversation"
                    style="-fx-background-color: rgba(34,211,238,0.08); -fx-text-fill: #22D3EE; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 9 12 9 12; -fx-border-color: rgba(34,211,238,0.2); -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>

            <Region minHeight="16"/>

            <Label text="CONVERSACIONES"
                   style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 10px; -fx-text-fill: #4B5563; -fx-letter-spacing: 1px; -fx-padding: 0 0 6 0;"/>

            <!-- Lista conversaciones -->
            <ListView fx:id="conversationList"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background-insets: 0; -fx-padding: 0;"/>

            <!-- Footer usuario -->
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-padding: 12 0 0 0; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 1 0 0 0;">
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #A855F7, #22D3EE); -fx-background-radius: 8; -fx-min-width: 32; -fx-min-height: 32; -fx-max-width: 32; -fx-max-height: 32;" alignment="CENTER">
                    <Label fx:id="avatarLabel" text="U"
                           style="-fx-font-family: 'JetBrains Mono'; -fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #080A10;"/>
                </VBox>
                <Label fx:id="usernameLabel" text="Usuario"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px; -fx-text-fill: #F0F9FF;"
                       HBox.hgrow="ALWAYS"/>
                <Button text="Salir"
                        onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #6B7280; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 4 8 4 8; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 6; -fx-border-width: 1; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </left>

    <!-- ÁREA PRINCIPAL -->
    <center>
        <VBox style="-fx-background-color: #0B0D15;">

            <!-- Header -->
            <HBox style="-fx-background-color: rgba(11,13,21,0.8); -fx-padding: 16 24 16 24; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="chatTitleLabel" text=">_ chat"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px; -fx-text-fill: #22D3EE;"
                       HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="6">
                    <Region style="-fx-background-color: #10B981; -fx-background-radius: 99; -fx-min-width: 7; -fx-min-height: 7; -fx-max-width: 7; -fx-max-height: 7;"/>
                    <Label text="online"
                           style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11px; -fx-text-fill: #8B9BB4;"/>
                </HBox>
            </HBox>

            <!-- Mensajes -->
            <ScrollPane fx:id="scrollPane"
                        VBox.vgrow="ALWAYS"
                        fitToWidth="true"
                        style="-fx-background-color: #0B0D15; -fx-background: #0B0D15; -fx-border-color: transparent; -fx-padding: 0;">
                <VBox fx:id="messagesContainer"
                      spacing="24"
                      style="-fx-padding: 32 24 32 24; -fx-background-color: #0B0D15;"/>
            </ScrollPane>

            <!-- Input -->
            <HBox style="-fx-background-color: rgba(11,13,21,0.9); -fx-padding: 16 24 20 24; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 1 0 0 0;"
                  spacing="10" alignment="BOTTOM_CENTER">
                <TextArea fx:id="messageInput"
                          promptText="Escribe tu pregunta de programación..."
                          HBox.hgrow="ALWAYS"
                          prefRowCount="2"
                          wrapText="true"
                          style="-fx-background-color: #10121C; -fx-text-fill: #F0F9FF; -fx-prompt-text-fill: #4B5563; -fx-background-radius: 10; -fx-padding: 13 16 13 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 10; -fx-border-width: 1; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px;"/>
                <Button fx:id="sendButton"
                        text="→"
                        onAction="#sendMessage"
                        style="-fx-background-color: linear-gradient(to bottom right, #A855F7, #22D3EE); -fx-text-fill: #0B0D15; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 10; -fx-min-width: 44; -fx-min-height: 44; -fx-max-width: 44; -fx-max-height: 44; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>