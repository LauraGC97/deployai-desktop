<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.deployai.controller.LoginController"
           style="-fx-background-color: #080A10;">

    <VBox alignment="CENTER" spacing="0" maxWidth="440"
          style="-fx-padding: 24;">

        <!-- Logo SVG animado -->
        <WebView fx:id="logoView"
                 prefWidth="100" prefHeight="100"
                 maxWidth="100" maxHeight="100"
                 style="-fx-background-color: transparent;"/>

        <Region minHeight="8"/>

        <!-- Título -->
        <VBox alignment="CENTER" spacing="4" style="-fx-padding: 0 0 20 0;">
            <Label text="Deploy AI"
                   style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #F0F9FF;"/>
            <Label text="Tu asistente de programación"
                   style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
        </VBox>

        <!-- Tarjeta -->
        <VBox spacing="18"
              style="-fx-background-color: #161922; -fx-background-radius: 16; -fx-padding: 36; -fx-border-color: rgba(34,211,238,0.12); -fx-border-radius: 16; -fx-border-width: 1;">

            <VBox spacing="4">
                <Label text="Hola de nuevo, developer!"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #F0F9FF;"/>
                <Label text="Introduce tus credenciales para continuar"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="EMAIL"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11px; -fx-text-fill: #8B9BB4;"/>
                <TextField fx:id="emailField"
                           promptText="tu@email.com"
                           style="-fx-background-color: #0D0F18; -fx-text-fill: #F0F0F0; -fx-prompt-text-fill: #4B5563; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-border-width: 1; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="CONTRASEÑA"
                       style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11px; -fx-text-fill: #8B9BB4;"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               style="-fx-background-color: #0D0F18; -fx-text-fill: #F0F0F0; -fx-prompt-text-fill: #4B5563; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-border-width: 1; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px;"/>
            </VBox>

            <Label fx:id="errorLabel" text=""
                   style="-fx-background-color: rgba(239,68,68,0.1); -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 12px; -fx-text-fill: #F87171; -fx-border-color: rgba(239,68,68,0.3); -fx-border-radius: 8; -fx-border-width: 1;"
                   wrapText="true" managed="false" visible="false"/>

            <Button fx:id="loginButton"
                    text="Entrar →"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    styleClass="btn-gradient"/>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="¿No tienes cuenta?"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                <Hyperlink text="Regístrate aquí"
                           onAction="#goToRegister"
                           style="-fx-text-fill: #00E5FF; -fx-font-family: 'JetBrains Mono'; -fx-font-size: 13px; -fx-border-color: transparent;"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>
